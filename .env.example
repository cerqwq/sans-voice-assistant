# Voice Assistant Configuration
# Copy this file to .env and fill in your API keys

# Required: Anthropic Claude API Key
ANTHROPIC_API_KEY=sk-ant-xxx

# Optional: OpenAI API Key (only if using OpenAI TTS instead of Edge TTS)
# OPENAI_API_KEY=sk-xxx

# Optional: Picovoice Key (only if using Porcupine wake word instead of OpenWakeWord)
# PICOVOICE_ACCESS_KEY=xxx

# Settings (defaults shown)
# CLAUDE_MODEL=claude-sonnet-4-20250514
# TTS_VOICE=zh-CN-XiaoxiaoNeural
# WAKE_WORDS=hey jarvis
# LANGUAGE=zh
# WHISPER_MODEL=base
